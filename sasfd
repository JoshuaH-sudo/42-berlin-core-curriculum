static char	*get_next_line_loop(int fd, char *buffer, char *line, ssize_t nread)
{
	while (1)
	{
		line = parse_line_from_buffer(buffer, line, nread);
		if (find_newline(line) != -1)
			return (line);
		nread = read(fd, buffer, BUFFER_SIZE);
		if (nread <= 0)
		{
			if (line[0] != '\0')
				return (line);
			free(line);
			return (NULL);
		}
		buffer[nread] = '\0';
	}
}
